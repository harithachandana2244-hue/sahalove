<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For You! ❤️</title>
    <style>
        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #ffe5ec, #ffc2d1);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
            text-align: center;
            position: relative;
        }

        /* Floating background hearts */
        .heart-bg {
            position: absolute;
            color: rgba(255, 75, 110, 0.2);
            font-size: 24px;
            animation: floatUp 6s linear infinite;
            bottom: -50px;
            z-index: 1;
            user-select: none;
            pointer-events: none;
        }

        @keyframes floatUp {
            0% {
                transform: translateY(0) rotate(0deg);
                opacity: 1;
            }
            100% {
                transform: translateY(-105vh) rotate(360deg);
                opacity: 0;
            }
        }

        .container {
            background: white;
            padding: 35px 25px;
            border-radius: 25px;
            box-shadow: 0 15px 35px rgba(255, 75, 110, 0.25);
            width: 85%;
            max-width: 360px;
            position: relative;
            z-index: 2;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        }

        h1 {
            color: #ff4b6e;
            font-size: 1.8rem;
            margin-bottom: 15px;
            margin-top: 0;
        }

        .warning-text {
            color: #ff6584;
            font-size: 1.1rem;
            font-weight: 600;
            margin-top: 0;
            margin-bottom: 25px;
        }

        .buttons-wrapper {
            display: flex;
            justify-content: center;
            gap: 20px;
            width: 100%;
            height: 55px; 
            position: relative;
            align-items: center;
            transition: height 0.2s ease;
        }

        button {
            padding: 14px 28px;
            font-size: 1.2rem;
            border: none;
            border-radius: 25px;
            cursor: pointer;
            font-weight: bold;
            transition: transform 0.1s ease;
            touch-action: manipulation;
        }

        #yesBtn {
            background-color: #ff4b6e;
            color: white;
            box-shadow: 0 5px 15px rgba(255, 75, 110, 0.4);
            z-index: 5;
        }

        #yesBtn:active {
            transform: scale(0.95);
        }

        #noBtn {
            background-color: #f0f0f0;
            color: #333;
            z-index: 10;
            transition: left 0.15s ease, top 0.15s ease; 
        }

        .hidden {
            display: none !important;
        }

        .celebration h1 {
            font-size: 2.2rem;
            animation: bounce 0.5s infinite alternate;
        }

        .video-container {
            margin-top: 20px;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.15);
            background: #000;
        }

        video {
            width: 100%;
            display: block;
        }

        @keyframes bounce {
            from { transform: translateY(0); }
            to { transform: translateY(-10px); }
        }
    </style>
</head>
<body>

    <div id="questionArea" class="container">
        <h1>Do you love me? 🥺💕</h1>
        <p class="warning-text">Click No if you dare😁</p>
        <div class="buttons-wrapper" id="btnWrapper">
            <button id="yesBtn" onclick="showLove()">Yes!</button>
            <button id="noBtn" onmouseover="moveButton(event)" ontouchstart="moveButton(event)" onclick="moveButton(event)">No</button>
        </div>
    </div>

    <div id="loveArea" class="container celebration hidden">
        <h1>I Love You Tooo! 😁🎉❤️✨</h1>
        <!-- <p>I knew you'd say yes! 😉</p> -->
        
        <div class="video-container">
            <video controls autoplay muted playsinline loop>
                <source src="C:\Users\harit\Downloads\Baaavaaaa.mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
    </div>

    <script>
        function createHearts() {
            const symbols = ['❤️', '💖', '💝', '💕', '🌸'];
            for (let i = 0; i < 15; i++) {
                const heart = document.createElement('div');
                heart.classList.add('heart-bg');
                heart.innerText = symbols[Math.floor(Math.random() * symbols.length)];
                heart.style.left = Math.random() * 100 + 'vw';
                heart.style.animationDelay = Math.random() * 5 + 's';
                heart.style.fontSize = Math.floor(Math.random() * 20 + 15) + 'px';
                document.body.appendChild(heart);
            }
        }
        createHearts();

        function moveButton(e) {
            if(e) e.preventDefault();

            const noBtn = document.getElementById('noBtn');
            const yesBtn = document.getElementById('yesBtn');
            const wrapper = document.getElementById('btnWrapper');
            
            wrapper.style.height = '180px';
            noBtn.style.position = 'absolute';
            
            const maxX = wrapper.clientWidth - noBtn.clientWidth;
            const maxY = wrapper.clientHeight - noBtn.clientHeight;
            
            const yesRect = yesBtn.getBoundingClientRect();
            const wrapperRect = wrapper.getBoundingClientRect();
            const yesX = yesRect.left - wrapperRect.left;
            const yesY = yesRect.top - wrapperRect.top;

            let randomX, randomY;
            let attempts = 0;
            let overlapping = true;

            while (overlapping && attempts < 20) {
                randomX = Math.floor(Math.random() * maxX);
                randomY = Math.floor(Math.random() * maxY);
                
                const xDistance = Math.abs(randomX - yesX);
                const yDistance = Math.abs(randomY - yesY);

                if (xDistance > 80 || yDistance > 50) {
                    overlapping = false;
                }
                attempts++;
            }
            
            noBtn.style.left = randomX + 'px';
            noBtn.style.top = randomY + 'px';
        }

        function showLove() {
            document.getElementById('questionArea').classList.add('hidden');
            document.getElementById('loveArea').classList.remove('hidden');
            document.body.style.background = "linear-gradient(135deg, #ffc2d1, #ff85a2)";
            
            const video = document.querySelector('video');
            if(video) {
                video.play().catch(err => console.log("Autoplay handled."));
            }
        }
    </script>
</body>
</html>
